{
  "name": "miniscript-vscode",
  "displayName": "miniscript-vscode",
  "description": "Execute MiniScript and view results.",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.109.0"
  },
  "categories": [
    "Other"
  ],
  "extensionKind": ["workspace"],
  "activationEvents": [
    "onLanguage:miniscript"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "miniscript.compileFile",
        "title": "MiniScript: Compile File"
      },
      {
        "command": "miniscript.runFile",
        "title": "MiniScript: Run File"
      },
      {
        "command": "miniscript.cancelRun",
        "title": "MiniScript: Cancel Run"
      }
    ],
    "configuration": {
      "properties": {
        "miniscript.runnerPath": {
          "type": "string",
          "description": "Path to MiniScript CLI executable."
        },
		"miniscript.compileOnSave": {
			"type": "boolean",
			"default": true,
			"description": "Compile MiniScript files automatically when saved."
		}
	  },
	  "languages": [
		{
		  "id": "miniscript",
		  "extensions": [".ms"],
		  "aliases": ["MiniScript"]
		}
	  ]
    },
	"debuggers": [
	  {
		"type": "miniscript",
		"label": "MiniScript",
		"languages": ["miniscript"],
		"program": "./dist/extension.js",
		"runtime": "node",
		"configurationAttributes": {
		  "launch": {
			"required": ["program"],
			"properties": {
			  "program": {
				"type": "string",
				"description": "MiniScript file to debug"
			  }
			}
		  }
		}
	  }
	],
    "menus": {
      "commandPalette": [
		{
			"command": "miniscript.compileFile"
		},
        {
          "command": "miniscript.runFile",
          "when": "!miniscript.isRunning"
        },
        {
          "command": "miniscript.cancelRun",
          "when": "miniscript.isRunning"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "webpack",
    "watch": "webpack --watch",
    "package": "webpack --mode production --devtool hidden-source-map",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.109.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "typescript-eslint": "^8.56.1",
    "eslint": "^9.39.3",
    "typescript": "^5.9.3",
    "ts-loader": "^9.5.4",
    "webpack": "^5.105.3",
    "webpack-cli": "^6.0.1",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2"
  }
}
